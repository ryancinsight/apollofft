# Cargo build outputs
/target/

# Python build outputs
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/.mypy_cache/
**/.venv/
**/dist/
**/build/
**/*.so
**/*.pyd

# Fuzzing artifacts
/fuzz/artifacts/
/fuzz/corpus/

# External comparators stay untracked except the README
/external/*
!/external/README.md

# Local benchmark outputs
/external/results/*
!/external/results/.gitkeep

# Scratch and temporary development artifacts
/validation_output*.json
/apollo_status.txt
/_*.py
/_*.txt
/_*.rs
/test_*.txt
/test_out.txt
/test_rust.rs
/gen_*.py
/tmp_*.py
/write_*.py
/scratch/
nul
